{"ts":"2026-04-28T18:09:36.994Z","sessionID":"ses_22ae4f4e2ffeIDmnESvWGT7CPo","agent":"architect","tool":"bash","command":"uv run python - <<'PY'\nfrom pathlib import Path\nimport pandas as pd\nfor p in Path('results').glob('*features*.csv'):\n    try:\n        df=pd.read_csv(p, nrows=1)\n    except Exception as e:\n        print(p, 'ERR', e); continue\n    hits={pat:[c for c in df.columns if pat.lower() in c.lower()] for pat in ['FreeAcc','Roll','Pitch','Yaw','Euler','acc_e','free']}\n    print('\\n',p,'ncols',len(df.columns))\n    for pat, cols in hits.items():\n        if cols:\n            print(' ',pat,len(cols),cols[:8])\nPY"}
{"ts":"2026-04-28T18:10:54.785Z","sessionID":"ses_22ae4f4e2ffeIDmnESvWGT7CPo","agent":"architect","tool":"bash","command":"uv run python - <<'PY'\nfrom pathlib import Path\nimport pandas as pd, re\nfor p in [Path('results/ablation_v3_features.csv'),Path('results/v3_features.csv')]:\n    df=pd.read_csv(p, nrows=1)\n    cols=list(df.columns)\n    pats=['_ro','_pi','_ya','roll','pitch','yaw','FreeAcc','free','acc','gyr','gm','am','trn_','fc_','ev_']\n    print('\\nFILE',p,'ncols',len(cols))\n    for pat in pats:\n        m=[c for c in cols if pat.lower() in c.lower()]\n        print(f'{pat}: {len(m)} sample={m[:12]}')\n    prefixes={}\n    for c in cols:\n        pref=c.split('_')[0]\n        prefixes[pref]=prefixes.get(pref,0)+1\n    print('top prefixes', sorted(prefixes.items(), key=lambda x:x[1], reverse=True)[:25])\nPY"}
{"ts":"2026-04-28T18:11:04.434Z","sessionID":"ses_22ae4f4e2ffeIDmnESvWGT7CPo","agent":"architect","tool":"bash","command":"uv run python - <<'PY'\nimport pandas as pd\nfrom project_paths import results_artifact_path\np=results_artifact_path('ablation_v3_features.csv')\ndf=pd.read_csv(p,nrows=1)\nexcluded_prefixes=('nl_','sv_','pa_','fq_','hr_','ix_','ext_')\nfor pref in excluded_prefixes:\n    cols=[c for c in df.columns if c.startswith(pref)]\n    print(pref, len(cols), cols[:20])\nPY"}
