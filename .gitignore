# === Regenerable artifacts (from uv.lock / pyproject.toml) ===
.venv/
venv/
env/
.uv/

# === Python bytecode / cache ===
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.pytest_cache/

# === Raw data (52 GB, download via synapse_download.py) ===
data/

# === Large binary caches (regenerable, exceed GitHub 100 MB limit) ===
**/rocket_recordings.npz

# === Nested results mirror (gpu.sh --pull artifact duplication) ===
results/results/

# === Secrets / credentials ===
.env
*.key
*.pem
synapse_credentials.json
TOKEN.md
GPU.md
.access_submissions/
.access_approvals/
.schema_probes/

# === OS / editor junk ===
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# === Third-party tracking (use native tools instead) ===
wandb/
mlruns/
tensorboard/
catboost_info/

# === Ephemeral session/telemetry state (Claude Code + SWARM harness) ===
.claude/scheduled_tasks.lock
.swarm/session/shell-audit.jsonl
.swarm/session/state.json
.swarm/telemetry.jsonl
.swarm/review-receipts/index.json
.swarm/repo-graph.json
.swarm/curator-briefing.md

# === Logs (ephemeral run artifacts; not paper evidence) ===
*.log
results/*.log
results/**/*.log
